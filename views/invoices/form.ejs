<%- include('../partials/header') %>
<div class="page-header">
  <h1><%= t('new_invoice') %></h1>
  <a href="/app/invoices" class="muted">← <%= t('invoices') %></a>
</div>

<div class="card form-card">
  <form method="POST" action="/app/invoices" id="invForm">
    <div class="grid-2">
      <div>
        <label><%= t('invoice_number') %> *</label>
        <input type="text" name="invoice_number" required value="<%= invoice.invoice_number %>">
      </div>
      <div>
        <label><%= t('customer') %></label>
        <select name="customer_id" onchange="fillBuyerFromCustomer(this)">
          <option value="">— Select —</option>
          <% customers.forEach(c => { %>
            <option value="<%= c.id %>" data-name="<%= c.name %>" data-address="<%= c.address || '' %>" data-pan="<%= c.pan || '' %>"><%= c.name %><%= c.phone ? ' (' + c.phone + ')' : '' %></option>
          <% }); %>
        </select>
      </div>
    </div>

    <h2 class="form-section-h">Buyer Information</h2>
    <div class="grid-3">
      <div>
        <label>Buyer's Name</label>
        <input type="text" name="buyer_name" value="<%= invoice.buyer_name || '' %>">
      </div>
      <div>
        <label>Buyer's Address</label>
        <input type="text" name="buyer_address" value="<%= invoice.buyer_address || '' %>">
      </div>
      <div>
        <label>Buyer's PAN</label>
        <input type="text" name="buyer_pan" value="<%= invoice.buyer_pan || '' %>">
      </div>
    </div>

    <div class="grid-2">
      <div>
        <label><%= t('invoice_date') %> *</label>
        <input type="date" name="invoice_date" required value="<%= invoice.invoice_date %>">
      </div>
      <div>
        <label><%= t('due_date') %></label>
        <input type="date" name="due_date" value="<%= invoice.due_date || '' %>">
      </div>
    </div>

    <h2 class="form-section-h">Items</h2>
    <table class="items-table">
      <thead>
        <tr>
          <th class="col-prod">Pick product</th>
          <th>Description</th>
          <th class="col-qty"><%= t('qty') %></th>
          <th class="col-rate"><%= t('rate') %></th>
          <th class="col-amt"><%= t('amount') %></th>
          <th></th>
        </tr>
      </thead>
      <tbody id="itemsBody"></tbody>
    </table>
    <button type="button" class="btn btn-outline" onclick="addItem()">+ <%= t('add_item') %></button>

    <div class="grid-2 mt-lg">
      <div>
        <h2 class="form-section-h">Payment</h2>
        <div class="grid-2">
          <div>
            <label><%= t('status') %></label>
            <select name="status">
              <option value="draft">Draft</option>
              <option value="sent">Sent</option>
              <option value="paid">Paid</option>
              <option value="partial">Partial</option>
            </select>
          </div>
          <div>
            <label><%= t('payment_method') %></label>
            <select name="payment_method">
              <option value="">—</option>
              <option>Cash</option>
              <option>eSewa</option>
              <option>Khalti</option>
              <option>IME Pay</option>
              <option>ConnectIPS</option>
              <option>Bank Transfer</option>
              <option>Credit</option>
            </select>
          </div>
        </div>
        <label><%= t('notes') %></label>
        <textarea name="notes" rows="2"></textarea>
      </div>

      <div>
        <h2 class="form-section-h">Totals</h2>
        <div class="totals-box">
          <div class="totals-row">
            <span><%= t('subtotal') %></span>
            <strong id="subtotalDisp">Rs 0</strong>
          </div>
          <div class="totals-row">
            <span><%= t('discount') %> (Rs)</span>
            <input type="number" name="discount" id="discount" step="0.01" value="0" style="width:100px; text-align:right;">
          </div>
          <div class="totals-row">
            <label class="cb-inline"><input type="checkbox" name="apply_vat" id="applyVat" value="1" checked> <%= t('apply_vat') %></label>
            <div>
              <input type="number" name="vat_rate" id="vatRate" step="0.01" value="<%= invoice.vat_rate %>" style="width:60px; text-align:right;">%
            </div>
          </div>
          <div class="totals-row">
            <span><%= t('vat') %></span>
            <strong id="vatDisp">Rs 0</strong>
          </div>
          <div class="totals-row totals-final">
            <span><%= t('total') %></span>
            <strong id="totalDisp">Rs 0</strong>
          </div>
        </div>
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= t('create_invoice') %></button>
      <a href="/app/invoices" class="btn btn-outline"><%= t('cancel') %></a>
    </div>
  </form>
</div>

<script>
const PRODUCTS = <%- JSON.stringify(products.map(p => ({id:p.id, name:p.name, name_ne:p.name_ne, price:p.price, vat:p.vat_applicable}))) %>;
let itemCount = 0;

function fillBuyerFromCustomer(sel) {
  const opt = sel.options[sel.selectedIndex];
  if (opt.value) {
    document.querySelector('[name="buyer_name"]').value = opt.dataset.name || '';
    document.querySelector('[name="buyer_address"]').value = opt.dataset.address || '';
    document.querySelector('[name="buyer_pan"]').value = opt.dataset.pan || '';
  }
}

function addItem(desc='', qty=1, rate=0, prodId='') {
  itemCount++;
  const i = itemCount;
  const tr = document.createElement('tr');
  tr.className = 'item-row';
  tr.innerHTML = `
    <td>
      <select onchange="pickProd(this, ${i})">
        <option value="">— pick —</option>
        ${PRODUCTS.map(p => `<option value="${p.id}" data-price="${p.price}" data-name="${p.name.replace(/"/g,'&quot;')}">${p.name}</option>`).join('')}
      </select>
      <input type="hidden" name="item_product_id" id="prod${i}" value="${prodId}">
    </td>
    <td><input type="text" name="item_desc" id="desc${i}" value="${desc.replace(/"/g,'&quot;')}" placeholder="Description"></td>
    <td><input type="number" name="item_qty" id="qty${i}" value="${qty}" step="0.01" min="0" oninput="recalc()"></td>
    <td><input type="number" name="item_rate" id="rate${i}" value="${rate}" step="0.01" min="0" oninput="recalc()"></td>
    <td class="num amt-cell" id="amt${i}">Rs 0</td>
    <td><button type="button" class="btn-icon danger" onclick="this.closest('tr').remove(); recalc();">✕</button></td>
  `;
  document.getElementById('itemsBody').appendChild(tr);
  recalc();
}

function pickProd(sel, i) {
  const opt = sel.options[sel.selectedIndex];
  if (!opt.value) return;
  document.getElementById('prod'+i).value = opt.value;
  document.getElementById('desc'+i).value = opt.dataset.name;
  document.getElementById('rate'+i).value = opt.dataset.price;
  recalc();
}

function recalc() {
  let sub = 0;
  document.querySelectorAll('.item-row').forEach(row => {
    const q = parseFloat(row.querySelector('[name="item_qty"]').value) || 0;
    const r = parseFloat(row.querySelector('[name="item_rate"]').value) || 0;
    const amt = q * r;
    row.querySelector('.amt-cell').textContent = 'Rs ' + Math.round(amt).toLocaleString('en-IN');
    sub += amt;
  });
  const disc = parseFloat(document.getElementById('discount').value) || 0;
  const afterDisc = sub - disc;
  const vatOn = document.getElementById('applyVat').checked;
  const vRate = parseFloat(document.getElementById('vatRate').value) || 0;
  const vatAmt = vatOn ? afterDisc * vRate / 100 : 0;
  const total = afterDisc + vatAmt;
  document.getElementById('subtotalDisp').textContent = 'Rs ' + Math.round(sub).toLocaleString('en-IN');
  document.getElementById('vatDisp').textContent = 'Rs ' + Math.round(vatAmt).toLocaleString('en-IN');
  document.getElementById('totalDisp').textContent = 'Rs ' + Math.round(total).toLocaleString('en-IN');
}

document.getElementById('discount').addEventListener('input', recalc);
document.getElementById('applyVat').addEventListener('change', recalc);
document.getElementById('vatRate').addEventListener('input', recalc);

// Start with one empty row
addItem();
</script>
<%- include('../partials/footer') %>
