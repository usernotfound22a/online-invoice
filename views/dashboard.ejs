<%- include('partials/header') %>
<div class="page-header">
  <h1><%= t('dashboard') %></h1>
  <p class="muted"><%= t('welcome') %>, <%= user.business_name %></p>
</div>

<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-label"><%= t('revenue_this_month') %></div>
    <div class="stat-value"><%= fmt.moneyPlain(monthRevenue) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label"><%= t('outstanding') %></div>
    <div class="stat-value"><%= fmt.moneyPlain(outstanding) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label"><%= t('invoices_issued') %></div>
    <div class="stat-value"><%= invoiceCount %></div>
  </div>
  <div class="stat-card stat-action">
    <a href="/app/invoices/new" class="btn btn-primary btn-block">+ <%= t('new_invoice') %></a>
  </div>
</div>

<div class="grid-cols-2">
  <div class="card">
    <h2>6-month revenue</h2>
    <div class="chart-bars">
      <% const max = Math.max(...revenueChart.map(r => r.total), 1); %>
      <% revenueChart.forEach(r => { %>
        <div class="bar-col">
          <div class="bar" style="height: <%= (r.total / max * 100) %>%"></div>
          <div class="bar-label"><%= r.month %></div>
          <div class="bar-val"><%= fmt.moneyPlain(r.total) %></div>
        </div>
      <% }); %>
    </div>
  </div>

  <div class="card">
    <h2><%= t('top_customers') %></h2>
    <% if (topCustomers.length === 0) { %>
      <p class="empty"><%= t('no_data') %></p>
    <% } else { %>
      <ul class="simple-list">
        <% topCustomers.forEach(c => { %>
          <li>
            <span><%= lang === 'ne' && c.name_ne ? c.name_ne : c.name %></span>
            <strong><%= fmt.moneyPlain(c.total) %></strong>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</div>

<div class="grid-cols-2">
  <div class="card">
    <h2><%= t('recent_invoices') %></h2>
    <% if (recentInvoices.length === 0) { %>
      <p class="empty"><%= t('no_data') %></p>
    <% } else { %>
      <table class="table-mini">
        <% recentInvoices.forEach(inv => { %>
          <tr>
            <td><a href="/app/invoices/<%= inv.id %>"><%= inv.invoice_number %></a></td>
            <td><%= inv.customer_name || '—' %></td>
            <td><span class="badge badge-<%= inv.status %>"><%= inv.status %></span></td>
            <td class="num"><%= fmt.moneyPlain(inv.total) %></td>
          </tr>
        <% }); %>
      </table>
    <% } %>
  </div>

  <div class="card">
    <h2><%= t('low_stock') %></h2>
    <% if (lowStock.length === 0) { %>
      <p class="empty"><%= t('no_data') %></p>
    <% } else { %>
      <ul class="simple-list">
        <% lowStock.forEach(p => { %>
          <li>
            <span><%= lang === 'ne' && p.name_ne ? p.name_ne : p.name %></span>
            <strong class="warning"><%= p.stock %> <%= p.unit %></strong>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
