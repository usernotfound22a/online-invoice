<%- include('partials/header') %>
<div class="auth-wrap">
  <div class="auth-card">
    <h1><%= t('login') %></h1>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <form method="POST" action="/auth/login">
      <label><%= t('email') %></label>
      <input type="email" name="email" required autofocus>
      <label><%= t('password') %></label>
      <input type="password" name="password" required>
      <button type="submit" class="btn btn-primary btn-block"><%= t('login') %></button>
    </form>

    <!-- Google Login -->
    <div style="margin: 20px 0; text-align: center;">
      <p style="color: #999; font-size: 12px; margin-bottom: 10px;">Or continue with</p>
      <a href="/auth/google" class="btn btn-google" style="background: #fff; color: #333; border: 1px solid #ddd; display: flex; align-items: center; justify-content: center; gap: 10px; font-weight: 500;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="1"></circle>
          <circle cx="19" cy="12" r="1"></circle>
          <circle cx="5" cy="12" r="1"></circle>
        </svg>
        Login with Google
      </a>
    </div>

    <p class="auth-alt"><%= t('signup') %>? <a href="/auth/signup"><strong><%= t('signup') %></strong></a></p>
    <div class="demo-creds">
      <strong>Demo credentials:</strong><br>
      Business: demo@pokhara.local / demo1234<br>
      Admin: admin@pokhara.local / admin1234
    </div>
    <div class="lang-toggle auth-lang">
      <a href="/lang/en" class="<%= lang === 'en' ? 'active' : '' %>">EN</a>
      <a href="/lang/ne" class="<%= lang === 'ne' ? 'active' : '' %>">ने</a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
