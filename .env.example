# Pokhara Invoice - Environment Variables
# Copy this file to .env and fill in your values

# ============= MONGODB =============
# Get your connection string from: https://cloud.mongodb.com
MONGODB_URL=mongodb+srv://username:password@cluster0.xxxx.mongodb.net/pokhara_invoice?retryWrites=true&w=majority

# ============= SESSION =============
# Generate secure secret: openssl rand -hex 32
# Windows: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 64 | % {[char]$_})
SESSION_SECRET=change-this-to-a-random-64-character-string-in-production

# ============= ENVIRONMENT =============
NODE_ENV=development
# Change to 'production' when deploying

# ============= SERVER =============
PORT=3000
WORKERS=max
# Set WORKERS to specific number to limit (e.g., 2, 4, 8)
# Default: 'max' uses all available CPU cores

# ============= REDIS (Optional, for distributed sessions) =============
# Only set this if you have Redis running
# Format: redis://username:password@host:port
# REDIS_URL=redis://localhost:6379

# ============= CORS (Optional) =============
# Restrict which domains can access your API
# CORS_ORIGIN=https://yourdomain.com
# CORS_ORIGIN=* (for development only)

# ============= HTTPS (Optional) =============
# HTTPS=true
# Set to true if your server runs behind HTTPS proxy (Nginx, Load Balancer)

# ============= Deployment Specific =============
# Railway.app, Heroku, DigitalOcean will override these automatically
# No changes needed if deploying to managed platforms
